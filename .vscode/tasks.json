{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "Run Next.js Frontend",
			"command": "pnpm dev",
			"options": {
				"env": {
					"NODE_OPTIONS": "--max-old-space-size=4096"
				}
			},
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}